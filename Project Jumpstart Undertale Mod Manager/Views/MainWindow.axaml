<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Project_Jumpstart_Undertale_Mod_Manager.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Project_Jumpstart_Undertale_Mod_Manager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        FontFamily="{StaticResource DeterminationFont}"
        Icon="/Assets/avalonia-logo.ico"
        Title="Project_Jumpstart_Undertale_Mod_Manager">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="100,*, Auto">
        
        <Image Source="/Assets/project_jumpstart_logo.png" VerticalAlignment="Center" HorizontalAlignment="Center"></Image>

        <!-- Row 0: Discrete Credits Button -->
        <Button Grid.Row="0" 
                Content="Credits" 
                Command="{Binding ToggleCreditsCommand}"
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Margin="10" 
                Background="Transparent" 
                Foreground="Gray" 
                Cursor="Hand"/>
        
        <ContentControl Grid.Row="1" Content="{Binding SelectedGame}"/>
        
        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Padding="10" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Save &amp; Play" Command="{Binding SaveAndPlayCommand}"/>
                <Button Content="Save"/>
                <ComboBox ItemsSource="{Binding Games}"
                          SelectedItem="{Binding SelectedGame}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:GameViewModel">
                            <TextBlock Text="{Binding GameName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Add Game" Command="{Binding AddGameCommand}"></Button>
            </StackPanel>
        </Border>
        <!-- Credits Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="3" 
              Background="#CC000000" 
              IsVisible="{Binding ShowCredits}">
            
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" 
                    BorderBrush="Gray" BorderThickness="1" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Padding="30">
                <StackPanel Spacing="15" HorizontalAlignment="Center">
                    <TextBlock Text="CREDITS" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="Developer Lead: SonicJoshua24" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ideas &amp; Feedback: Ethan, Lazybones" HorizontalAlignment="Center"/>
                    
                    <Button Content="Close" 
                            Command="{Binding ToggleCreditsCommand}" 
                            HorizontalAlignment="Center" 
                            Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
