<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Project_Jumpstart_Undertale_Mod_Manager.ViewModels"
             xmlns:conv="using:Project_Jumpstart_Undertale_Mod_Manager.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:GameViewModel"
             x:Class="Project_Jumpstart_Undertale_Mod_Manager.Views.GameView">
    <!-- Main Tabs -->
    <TabControl Grid.Row="1">
        <TabItem Header="Mods">
            <Grid ColumnDefinitions="40, 1.5*, *" RowDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,20,0,0" Spacing="5">
                    <Button Content="↑" Width="30"/>
                    <Button Content="↓" Width="30"/>
                </StackPanel>
                <DataGrid Grid.Column="1" Grid.Row="0" Margin="10" 
                          ItemsSource="{Binding Mods}" 
                          SelectedItem="{Binding SelectedMod}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="False"
                          GridLinesVisibility="All"
                          BorderThickness="1" BorderBrush="Gray">
                    <DataGrid.Columns>
                        <!-- Checkbox for toggling the mod -->
                        <DataGridCheckBoxColumn Binding="{Binding IsEnabled}" />
    
                        <!-- Text columns for the mod details -->
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="Author" Binding="{Binding Author}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="Version" Binding="{Binding Version}" IsReadOnly="True" Width="Auto" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" IsReadOnly="True" Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Right Sidebar Buttons -->
                <StackPanel Grid.Column="2" Grid.Row="0" Margin="5" Spacing="5">
                    <!-- Artwork Preview Box -->
                    <Border BorderBrush="Gray" BorderThickness="1" MinHeight="150" Margin="0,10,0,5" Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                        <Image Source="{Binding SelectedMod.FullImagePath, Converter={x:Static conv:PathToBitmapConverter.Instance}}" Stretch="Uniform"/>
                    </Border>
    
                    <!-- Upload Button -->
                    <Button Content="Upload Art" Command="{Binding UploadArtCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <!-- Refresh / Add Mod Bar -->
                <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Margin="10" Spacing="10">
                    <Button Content="Refresh"/>
                    <!-- Bound to ViewModel Command -->
                    <Button Content="+ Add Mod" Command="{Binding AddModCommand}"/>
                    <Button Content="Create Mod" Command="{Binding CreateModCommand}"/>
                </StackPanel>
            </Grid>
        </TabItem>
        
        <TabItem Header="Codes"/>
        <TabItem Header="Game Config"/>
        
        <TabItem Header="Manager Config">
            <StackPanel Margin="10" Spacing="10">
                
                <TextBlock Text="Game Directory:" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBox Width="400" Text="{Binding GameDirectory}" IsReadOnly="True" Foreground="Gray"/>
                    <!-- You can bind a command here later to open the folder in your file manager -->
                    <Button Content="Open Folder"/>
                </StackPanel>

                <TextBlock Text="Target Executable:" FontWeight="Bold" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding Executables}"
                          SelectedItem="{Binding SelectedExecutable}"
                          Width="400"/>

                <TextBlock Text="Target Data Archive (.win / .unx):" FontWeight="Bold" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding DataFiles}"
                          SelectedItem="{Binding SelectedDataFile}"
                          Width="400"/>

            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>
